{
  "name": "opencode-md-management",
  "version": "0.1.0",
  "description": "Manage AI instruction markdown files for OpenCode",
  "main": "./dist/plugin.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hinen/opencode-md-management.git"
  },
  "homepage": "https://github.com/Hinen/opencode-md-management#readme",
  "bugs": {
    "url": "https://github.com/Hinen/opencode-md-management/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "opencode-md-management": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/plugin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.5",
    "commander": "^12.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
